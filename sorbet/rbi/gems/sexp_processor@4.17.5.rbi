  def inspect; end

  # pkg:gem/sexp_processor#lib/sexp_matcher.rb:582
  def pretty_print(q); end

  # Always satisfied once this is reached. Think of it as a var arg.
  #
  # pkg:gem/sexp_processor#lib/sexp_matcher.rb:570
  def satisfy?(o); end
end

